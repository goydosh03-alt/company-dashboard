---
import Shell from '../layouts/Shell.astro';
import content from '../fragments/figma.html?raw';
const overview = [
  { icon: 'apps', label: 'All files', cat: 'all', active: true },
  { divider: 'Categories' },
  { icon: 'dashboard', label: 'Design System', cat: 'Design System' },
  { icon: 'dark_mode', label: 'Themes', cat: 'Themes' },
  { icon: 'foundation', label: 'Foundations', cat: 'Foundations' },
  { icon: 'campaign', label: 'Marketing', cat: 'Marketing' },
  { icon: 'bug_report', label: 'Testing', cat: 'Testing' },
];
---
<Shell active="Figma" title="Figma" crumb="/ All files" overview={overview}>
  <Fragment set:html={content} />
  <script is:inline src="/js/figma.js"></script>
</Shell>
