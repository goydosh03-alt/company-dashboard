---
import Shell from '../layouts/Shell.astro';
import content from '../fragments/home.html?raw';
import uploadModal from '../fragments/_uploadmodal.html?raw';
import ctxMenu from '../fragments/_ctxmenu.html?raw';
---
<Shell active="Home" title="Home" crumb="/ Overview">
  <Fragment set:html={content} />
  <Fragment set:html={uploadModal} />
  <Fragment set:html={ctxMenu} />
  <script is:inline src="/js/plugins.js"></script>
  <script is:inline src="/js/home.js"></script>
</Shell>
