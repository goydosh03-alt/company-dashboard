---
import Shell from '../layouts/Shell.astro';
import content from '../fragments/components.html?raw';
const overview = [
  { icon: 'smart_button', label: 'Button', comp: 'button', active: true },
  { icon: 'edit_square', label: 'Input', comp: 'input' },
  { icon: 'toggle_on', label: 'Toggle', comp: 'toggle' },
  { icon: 'crop_square', label: 'Card', comp: 'card' },
  { icon: 'tab', label: 'Tabs', comp: 'tabs' },
];
---
<Shell active="Components" title="Components" crumb="/ Button" overview={overview}>
  <Fragment set:html={content} />
  <script is:inline src="/js/components.js"></script>
</Shell>
