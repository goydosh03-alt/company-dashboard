---
import Shell from '../layouts/Shell.astro';
import content from '../fragments/guidelines.html?raw';
const overview = [
  { icon: 'auto_awesome', label: 'About the system', scroll: '#gl-about', active: true },
  { divider: 'Foundations' },
  { icon: 'workspace_premium', label: 'Brand', scroll: '#gl-brand' },
  { icon: 'accessibility_new', label: 'Accessibility', scroll: '#gl-a11y' },
  { icon: 'grid_view', label: 'Layout & Grid', scroll: '#gl-layout' },
  { icon: 'touch_app', label: 'Interaction & States', scroll: '#gl-interaction' },
  { icon: 'edit_note', label: 'Content & Voice', scroll: '#gl-content' },
  { icon: 'volunteer_activism', label: 'Contribution', scroll: '#gl-contribution' },
];
---
<Shell active="Guidelines" title="Foundations" crumb="/ About the system" overview={overview}>
  <Fragment set:html={content} />
  <script is:inline src="/js/guidelines.js"></script>
</Shell>
